{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/apps/api-customer-service",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "types": ["node"],
    "emitDecoratorMetadata": true,
    "target": "es2022"
  },
  "exclude": [
    "vitest.config.ts",
    "vitest.config.integration.ts",
    "**/*.spec.ts",
    "**/*.test.ts",
    "tests/**/*"
  ],
  "include": ["src/**/*.ts"]
}
