{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "npmScope": "chatsuite",
  "neverConnectToCloud": true,
  "affected": {
    "defaultBase": "main"
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "cache": true
    },
    "e2e": {
      "inputs": ["default", "^production"],
      "cache": true
    },
    "test": {
      "inputs": ["default", "^production"],
      "cache": true
    },
    "integration": {
      "inputs": ["default", "^production"],
      "cache": false
    },
    "lint": {
      "inputs": ["default", "{workspaceRoot}/biome.json"],
      "cache": true
    }
  },
  "defaultProject": "api-customer-service",
  "generators": {
    "@nx/react": {
      "application": {
        "style": "css"
      },
      "component": {
        "style": "css"
      },
      "library": {
        "style": "css"
      }
    }
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": ["{workspaceRoot}/pnpm-workspace.yaml", "{workspaceRoot}/pnpm-lock.yaml"],
    "production": [
      "default",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
      "!{projectRoot}/tsconfig.spec.json",
      "!{projectRoot}/vitest.config*.ts"
    ]
  },
  "plugins": [],
  "analytics": false
}
